DATABASE_URL="postgresql://USER:PASSWORD@localhost:5437/DATABASE?schema=public"
PORT=3001

# Docker Postgres credentials (used by docker-compose.yml)
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=ecommerce_api

# Auth
JWT_SECRET="generate-with: openssl rand -hex 32"

# PayPal — copy from developer.paypal.com > Apps & Credentials
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""
PAYPAL_OAUTH_URL="https://api-m.sandbox.paypal.com/v1/oauth2/token"
PAYPAL_ORDERS_URL="https://api-m.sandbox.paypal.com/v2/checkout/orders"
